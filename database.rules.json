{
  "rules": {
    // Helper: Check if user is a hardcoded admin or has the admin role in DB
    "users": {
      ".indexOn": ["appId", "username"],
      // Allow all authenticated users to read the users list for the leaderboard
      ".read": "auth != null",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.email === 'siddharthptru@gmail.com')",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.email === 'siddharthptru@gmail.com')"
      }
    },
    "usernames": {
      ".read": "true",
      "$username": {
        ".write": "auth != null && (!data.exists() || data.val() === auth.uid)"
      }
    },
    "settings": {
      ".read": "true",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.email === 'siddharthptru@gmail.com')"
    },
    "leaderboard": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.email === 'siddharthptru@gmail.com')"
    },
    "tournaments": {
      ".read": "true",
      ".indexOn": ["status"],
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.email === 'siddharthptru@gmail.com')",
      "$tid": {
        "participants": {
          "$uid": {
            ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')"
          }
        }
      }
    },
    "transactions": {
      ".indexOn": ["timestamp"],
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.email === 'siddharthptru@gmail.com' || auth.token.email === 'user-siddharthptru@gmail.com' || auth.token.email === '37488473@gmail.com')",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.email === 'siddharthptru@gmail.com' || auth.token.email === 'user-siddharthptru@gmail.com' || auth.token.email === '37488473@gmail.com')"
    },
    "supportTickets": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["uid"]
    },
    "supportMessages": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "addMoneyRequests": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.email === 'siddharthptru@gmail.com' || query.orderByChild == 'uid' && query.equalTo == auth.uid)",
      ".write": "auth != null",
      ".indexOn": ["uid"]
    },
    "withdrawRequests": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.email === 'siddharthptru@gmail.com' || query.orderByChild == 'uid' && query.equalTo == auth.uid)",
      ".write": "auth != null",
      ".indexOn": ["uid"]
    },
    "reports": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.email === 'siddharthptru@gmail.com')",
      ".write": "auth != null"
    },
    "announcements": {
      ".read": "true",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.email === 'siddharthptru@gmail.com')"
    },
    "userNotifications": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },
    "auditLogs": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.email === 'siddharthptru@gmail.com')",
      ".write": "auth != null"
    },
    "dynamicFeatures": {
      ".read": "true",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.email === 'siddharthptru@gmail.com')"
    }
  }
}
